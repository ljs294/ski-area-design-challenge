{
  "name": "ski-area-design-challenge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "package": "tsc && vite build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4"
  },
  "build": {
    "appId": "com.lukesmall.mountainplanner",
    "productName": "Mountain Planner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "portable"
    }
  }
}
