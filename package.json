{
  "name": "ski-area-design-challenge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:lab": "node scripts/devLab.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "package": "tsc && vite build && electron-builder",
    "test": "vitest run",
    "download-preset": "tsx scripts/downloadPresetTerrain.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "geotiff": "^3.0.5",
    "leaflet": "^1.9.4",
    "maplibre-contour": "^0.1.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "build": {
    "appId": "com.lukesmall.mountainplanner",
    "productName": "Mountain Planner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "portable"
    }
  }
}
